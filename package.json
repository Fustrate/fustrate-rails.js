{
	"name": "@fustrate/rails",
	"version": "0.5.0",
	"description": "A frontend framework built for my personal projects because reinventing the wheel is obviously worth my time.",
	"license": "UNLICENSED",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Fustrate/fustrate-rails.js.git"
	},
	"files": ["**/*.ts", "!**/*.spec.ts"],
	"bugs": "https://github.com/Fustrate/fustrate-rails.js/issues",
	"dependencies": {
		"@popperjs/core": "^2.11.8",
		"es-toolkit": "^1.46.1",
		"ky": "^2.0.2",
		"reflect-metadata": "^0.2.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@happy-dom/global-registrator": "^20.9.0",
		"@types/bun": "^1.3.13",
		"@types/luxon": "^3.7.1",
		"jsdom": "^29.1.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"scripts": {
		"lint": "biome lint .",
		"lint:fix": "biome lint . --fix",
		"lint:format": "biome format . --fix",
		"precommit": "biome lint .",
		"test": "vitest run",
		"tsc": "tsc --incremental --project .",
		"tsc:watch": "bun run tsc --watch",
		"versions": "bun run ./lib/update-package-versions.js"
	}
}
